"The closing {bracket} on line {close_lineno} does not match the opening {open_bracket} on line {open_lineno}.\n"
msgstr ""
"O {bracket} de fechamento na linha {close_lineno} não corresponde ao {open_bracket} de abertura na linha {open_lineno}.\n"

#: syntax_errors\statement_analyzer.py:208
